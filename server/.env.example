# 后端环境变量模板（复制为 .env 后填入真实值；.env 不上传 Git）

# ====== 服务监听 ======
PORT=3000
HOST=127.0.0.1
NODE_ENV=production

# ====== MongoDB ======
MONGO_URI=mongodb://127.0.0.1:27017/couple_app

# ====== 微信小程序 ======
WX_APPID=你的小程序 AppID
WX_APPSECRET=你的小程序 AppSecret

# ====== JWT ======
JWT_SECRET=请用 openssl rand -base64 48 生成一个随机串
JWT_EXPIRES_IN=30d

# ====== 白名单（openid 无感登录）======
OWNER_OPENID=
CUSTOMER_OPENID=

# ====== 账号密码登录（首次启动种子用，之后可后台改）======
# 启动时如果数据库里没有同名用户，会自动创建
OWNER_USERNAME=owner
OWNER_PASSWORD=请改成你自己的强密码
OWNER_NICKNAME=店长

CUSTOMER_USERNAME=customer
CUSTOMER_PASSWORD=请改成她的强密码
CUSTOMER_NICKNAME=宝宝