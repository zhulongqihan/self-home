<view class="page">
  <view class="logo">🍵</view>
  <view class="title">我们的小窝</view>
  <view class="subtitle">请输入暗号进入店铺</view>

  <view class="input-wrap">
    <input
      class="input"
      type="text"
      password
      placeholder="暗号"
      value="{{password}}"
      bindinput="onPasswordInput"
      confirm-type="done"
      bindconfirm="onSubmit"
      maxlength="32" />
  </view>

  <view class="error" wx:if="{{errorMsg}}">{{errorMsg}}</view>

  <button class="btn-primary" bindtap="onSubmit" disabled="{{loading}}" loading="{{loading}}">
    {{loading ? '登录中...' : '进入店铺'}}
  </button>

  <view class="alt" bindtap="onTryWxLogin">使用微信号登录</view>
</view>