<view class="page">
  <view class="logo">🍵</view>
  <view class="title">我们的小窝</view>
  <view class="subtitle">请输入暗号进入店铺</view>

  <view class="input-wrap">
    <input
      class="input"
      type="text"
      password="{{true}}"
      placeholder="请输入暗号"
      placeholder-class="input-placeholder"
      value="{{password}}"
      bindinput="onPasswordInput"
      confirm-type="done"
      bindconfirm="onSubmit"
      maxlength="32"
    />
  </view>

  <view class="error" wx:if="{{errorMsg}}">{{errorMsg}}</view>

  <view
    class="btn-primary {{loading ? 'disabled' : ''}}"
    bindtap="onSubmit"
  >
    <text wx:if="{{loading}}">登录中...</text>
    <text wx:else>进入店铺</text>
  </view>

  <view class="alt" bindtap="onTryWxLogin">使用微信号登录</view>
</view>