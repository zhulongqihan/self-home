.launch {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: linear-gradient(180deg, #FDF6EC 0%, #FFFFFF 100%);
  padding: 40rpx;
}

.logo {
  font-size: 160rpx;
  margin-bottom: 40rpx;
  animation: bounce 1.4s ease-in-out infinite;
}

@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-20rpx); }
}

.status {
  color: #3D2C1E;
  font-size: 30rpx;
  letter-spacing: 2rpx;
}

.retry {
  margin-top: 60rpx;
  padding: 20rpx 60rpx;
  background: #E8B86D;
  color: #fff;
  border-radius: 40rpx;
  font-size: 28rpx;
}