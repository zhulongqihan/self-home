<view class="page">
  <view class="section">
    <text class="label">商品名称</text>
    <input
      class="input-line"
      data-field="name"
      value="{{form.name}}"
      bindinput="onInput"
      placeholder="如：珍珠奶茶"
      placeholder-class="field-placeholder"
    />
  </view>

  <view class="section">
    <text class="label">分类</text>
    <picker mode="selector" range="{{categories}}" range-key="name" value="{{categoryIndex}}" bindchange="onCategoryChange">
      <view class="picker-line">{{categories[categoryIndex].name || '请选择'}} ▾</view>
    </picker>
  </view>

  <view class="section row">
    <view class="half">
      <text class="label">价格（元）</text>
      <input class="input-line" type="digit" data-field="price" value="{{form.price}}" bindinput="onInput" placeholder-class="field-placeholder" />
    </view>
    <view class="half">
      <text class="label">库存</text>
      <input class="input-line" type="number" data-field="stock" value="{{form.stock}}" bindinput="onInput" placeholder-class="field-placeholder" />
    </view>
  </view>

  <view class="section">
    <text class="label">描述</text>
    <textarea class="input" data-field="description" value="{{form.description}}" bindinput="onInput" maxlength="200" />
  </view>

  <view class="section">
    <text class="label">展示图风格</text>
    <picker mode="selector" range="{{imageStyles}}" range-key="label" value="{{styleIndex}}" bindchange="onStyleChange">
      <view class="picker-line">{{imageStyles[styleIndex].label}} ▾</view>
    </picker>
    <text class="hint">选内置风格则厨房用 emoji 占位；也可填下方 URL 覆盖</text>
  </view>

  <view class="section">
    <text class="label">图片 URL（可选）</text>
    <input class="input-line" data-field="image_url" value="{{form.image_url}}" bindinput="onInput" placeholder="https://..." placeholder-class="field-placeholder" />
  </view>

  <view class="section">
    <view class="spec-head">
      <text class="label">规格（可选，可多条）</text>
      <text class="spec-add" bindtap="onAddSpec">+ 添加规格</text>
    </view>
    <view wx:for="{{specs}}" wx:key="index" class="spec-card">
      <view class="spec-card-head">
        <text class="spec-index">规格 {{index + 1}}</text>
        <text wx:if="{{specs.length > 1}}" class="spec-remove" data-index="{{index}}" bindtap="onRemoveSpec">删除</text>
      </view>
      <input
        class="input-line"
        data-index="{{index}}"
        data-field="name"
        value="{{item.name}}"
        bindinput="onSpecInput"
        placeholder="规格名，如：温度"
        placeholder-class="field-placeholder"
      />
      <input
        class="input-line mt"
        data-index="{{index}}"
        data-field="options"
        value="{{item.options}}"
        bindinput="onSpecInput"
        placeholder="选项，逗号分隔：热,去冰,少冰"
        placeholder-class="field-placeholder"
      />
    </view>
  </view>

  <view class="section row">
    <view class="half">
      <text class="label">排序权重</text>
      <input class="input-line" type="number" data-field="sort_weight" value="{{form.sort_weight}}" bindinput="onInput" placeholder-class="field-placeholder" />
    </view>
  </view>

  <view class="save-btn" bindtap="onSave">{{isEdit ? '保存修改' : '创建商品'}}</view>
</view>
