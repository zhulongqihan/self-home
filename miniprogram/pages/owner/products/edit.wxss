.page {
  min-height: 100vh;
  background: #fdf6ec;
  padding: 24rpx;
  padding-bottom: 48rpx;
  box-sizing: border-box;
}

.section {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
}

.row {
  display: flex;
  gap: 16rpx;
}

.half {
  flex: 1;
}

.label {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #3d2c1e;
  margin-bottom: 12rpx;
}

/* 单行 input：固定高度 + line-height，避免占位符/输入文字被裁切（与登录页同理） */
.input-line {
  width: 100%;
  height: 88rpx;
  min-height: 88rpx;
  line-height: 88rpx;
  background: #f8f0e8;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #3d2c1e;
  box-sizing: border-box;
}

.field-placeholder {
  color: #b0a090;
  font-size: 26rpx;
  line-height: 88rpx;
}

.picker-line {
  width: 100%;
  min-height: 88rpx;
  background: #f8f0e8;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #3d2c1e;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  line-height: 1.4;
}

.input {
  width: 100%;
  min-height: 160rpx;
  background: #f8f0e8;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  line-height: 1.5;
  color: #3d2c1e;
  box-sizing: border-box;
}

.hint {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #999;
}

.mt {
  margin-top: 12rpx;
}

.spec-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.spec-add {
  font-size: 24rpx;
  color: #c9986a;
}

.spec-card {
  background: #f8f0e8;
  border-radius: 12rpx;
  padding: 16rpx;
  margin-bottom: 12rpx;
}

.spec-card-head {
  display: flex;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.spec-index {
  font-size: 24rpx;
  color: #8f7560;
}

.spec-remove {
  font-size: 24rpx;
  color: #b07a6a;
}

.save-btn {
  margin-top: 24rpx;
  background: #e8b86d;
  color: #fff;
  text-align: center;
  padding: 28rpx;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
}
