.page {
  min-height: 100vh;
  background: #fdf6ec;
  box-sizing: border-box;
}

.content {
  padding: 32rpx;
  box-sizing: border-box;
}

.section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.label {
  font-size: 28rpx;
  font-weight: 600;
  color: #3d2c1e;
  margin-bottom: 16rpx;
}

.input {
  width: 100%;
  min-height: 160rpx;
  background: #f8f0e8;
  border-radius: 12rpx;
  padding: 16rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.char-count {
  margin-top: 8rpx;
  text-align: right;
  font-size: 22rpx;
  color: #999;
}

.input-line {
  width: 100%;
  height: 88rpx;
  background: #f8f0e8;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #3d2c1e;
  box-sizing: border-box;
}

.field-placeholder {
  color: #b0a090;
  font-size: 26rpx;
}

.save-btn {
  background: #e8b86d;
  color: #fff;
  text-align: center;
  padding: 28rpx;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.section-head {
  margin: 24rpx 0 16rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #3d2c1e;
}

.state-text {
  text-align: center;
  color: #999;
  font-size: 26rpx;
  padding: 40rpx 0;
}

.msg-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.msg-time {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.msg-content {
  font-size: 28rpx;
  color: #3d2c1e;
  line-height: 1.6;
}

.msg-image {
  width: 100%;
  height: 240rpx;
  border-radius: 12rpx;
  margin-top: 16rpx;
}

.msg-del {
  margin-top: 16rpx;
  text-align: right;
  font-size: 24rpx;
  color: #c9986a;
}
