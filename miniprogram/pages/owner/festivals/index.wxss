@import "../messages/index.wxss";
@import "../categories/index.wxss";

.picker-val {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  background: #f8f0e8;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #3d2c1e;
}

.color-dot {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  margin-left: 12rpx;
  border: 2rpx solid #eee;
}

.row.col {
  flex-direction: column;
  align-items: stretch;
}

.row.col .row-label {
  width: auto;
  margin-bottom: 8rpx;
}

.sub-label {
  font-size: 26rpx;
  color: #666;
  margin: 16rpx 0 12rpx;
}

.hint {
  font-size: 24rpx;
  color: #999;
  padding: 8rpx 0;
}

.product-picks {
  max-height: 320rpx;
  overflow-y: auto;
}

.pick-item {
  display: flex;
  align-items: center;
  padding: 12rpx 16rpx;
  border-radius: 12rpx;
  margin-bottom: 8rpx;
  background: #f8f0e8;
}

.pick-item.checked {
  background: #fff3e0;
}

.pick-check {
  width: 36rpx;
  font-size: 24rpx;
  color: #e8b86d;
}

.pick-name {
  font-size: 26rpx;
  color: #3d2c1e;
}

.color-bar {
  width: 8rpx;
  height: 64rpx;
  border-radius: 4rpx;
  margin-right: 16rpx;
}

.card-main {
  align-items: stretch;
}

.hint-box {
  background: #fffaf2;
  border: 1rpx solid #f0dcc0;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.hint-title {
  font-size: 26rpx;
  font-weight: 700;
  color: #3d2c1e;
  margin-bottom: 8rpx;
}

.hint-text {
  font-size: 24rpx;
  color: #666;
  line-height: 1.6;
}
