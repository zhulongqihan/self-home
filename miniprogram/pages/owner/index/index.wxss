.page {
  min-height: 100vh;
  background: #FDF6EC;
  box-sizing: border-box;
}

.content {
  padding: 40rpx 30rpx;
  box-sizing: border-box;
}

.header {
  text-align: center;
  margin-bottom: 40rpx;
}

.welcome-emoji {
  font-size: 72rpx;
  line-height: 1.2;
}

.store-name {
  margin-top: 16rpx;
  font-size: 30rpx;
  color: #C9986A;
  font-weight: 600;
}

.kiss-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 28rpx;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(61, 44, 30, 0.06);
}

.kiss-title {
  font-size: 26rpx;
  color: #999;
}

.kiss-num {
  font-size: 48rpx;
  font-weight: 700;
  color: #e8b86d;
  margin-top: 12rpx;
}

.kiss-last {
  font-size: 22rpx;
  color: #c9986a;
  margin-top: 8rpx;
}

.grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.tile {
  width: 48%;
  box-sizing: border-box;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 50rpx 20rpx;
  margin-bottom: 24rpx;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(232, 184, 109, 0.1);
}

.tile-active:active {
  opacity: 0.85;
  transform: scale(0.98);
}

.tile-disabled {
  opacity: 0.5;
}

.tile-icon {
  font-size: 80rpx;
}

.tile-name {
  margin-top: 16rpx;
  font-size: 30rpx;
  color: #3D2C1E;
  font-weight: 600;
}

.tile-status {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #ccc;
}

.logout {
  margin-top: 80rpx;
  text-align: center;
  color: #C9986A;
  font-size: 26rpx;
  padding: 30rpx;
}