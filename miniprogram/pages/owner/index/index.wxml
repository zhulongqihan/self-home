<view class="page">
  <page-header title="店长工作台" />
  <view class="content">
  <view class="header">
    <view class="welcome-emoji">🧑‍🍳</view>
    <view class="store-name">{{store.name || '我们的小窝'}}</view>
  </view>

  <view class="kiss-card" wx:if="{{kissCount7d >= 0}}">
    <view class="kiss-title">最近 7 天亲亲</view>
    <view class="kiss-num">{{kissCount7d}} 次</view>
    <view class="kiss-last" wx:if="{{kissLastAt}}">最近一次：{{kissLastAt}}</view>
  </view>

  <view class="grid">
    <view class="tile tile-active" data-key="products" bindtap="onTileTap">
      <view class="tile-icon">🛍️</view>
      <view class="tile-name">商品管理</view>
      <view class="tile-status">增删改与上下架</view>
    </view>
    <view class="tile tile-active" data-key="orders" bindtap="onTileTap">
      <view class="tile-icon">📦</view>
      <view class="tile-name">订单管理</view>
      <view class="tile-status">接单与状态流转</view>
    </view>
    <view class="tile tile-active" data-key="categories" bindtap="onTileTap">
      <view class="tile-icon">🏷️</view>
      <view class="tile-name">分类管理</view>
      <view class="tile-status">图标 · 排序 · 节日</view>
    </view>
    <view class="tile tile-active" data-key="festivals" bindtap="onTileTap">
      <view class="tile-icon">🎉</view>
      <view class="tile-name">节日管理</view>
      <view class="tile-status">Banner · 专属菜单</view>
    </view>
    <view class="tile tile-disabled" data-key="analytics">
      <view class="tile-icon">📊</view>
      <view class="tile-name">数据看板</view>
      <view class="tile-status">Phase 3</view>
    </view>
    <view class="tile tile-active" data-key="messages" bindtap="onTileTap">
      <view class="tile-icon">💬</view>
      <view class="tile-name">留言板</view>
      <view class="tile-status">每日一句 · 历史</view>
    </view>
    <view class="tile tile-active" data-key="settings" bindtap="onTileTap">
      <view class="tile-icon">⚙️</view>
      <view class="tile-name">系统配置</view>
      <view class="tile-status">欢迎页 / 倒计时</view>
    </view>
  </view>

  <view class="logout" bindtap="onLogout">退出登录</view>
  </view>
</view>