<view class="page">
  <view class="header">
    <view class="title">🧑‍🍳 店长工作台</view>
    <view class="store-name">{{store.name || '我们的小窝'}}</view>
  </view>

  <view class="grid">
    <view class="tile tile-active" data-key="products" bindtap="onTileTap">
      <view class="tile-icon">🛍️</view>
      <view class="tile-name">商品管理</view>
      <view class="tile-status">增删改与上下架</view>
    </view>
    <view class="tile tile-active" data-key="orders" bindtap="onTileTap">
      <view class="tile-icon">📦</view>
      <view class="tile-name">订单管理</view>
      <view class="tile-status">接单与状态流转</view>
    </view>
    <view class="tile tile-disabled" data-key="analytics">
      <view class="tile-icon">📊</view>
      <view class="tile-name">数据看板</view>
      <view class="tile-status">Phase 3</view>
    </view>
    <view class="tile tile-active" data-key="settings" bindtap="onTileTap">
      <view class="tile-icon">⚙️</view>
      <view class="tile-name">系统配置</view>
      <view class="tile-status">欢迎页文案/图片</view>
    </view>
  </view>

  <view class="logout" bindtap="onLogout">退出登录</view>
</view>