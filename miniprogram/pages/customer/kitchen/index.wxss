.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f5f5f5;
  box-sizing: border-box;
}

.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 24rpx;
  background: #fff;
}

.top-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #3d2c1e;
}

.search-placeholder {
  font-size: 24rpx;
  color: #999;
  background: #f5f5f5;
  padding: 12rpx 28rpx;
  border-radius: 999rpx;
}

.main {
  flex: 1;
  display: flex;
  min-height: 0;
}

.side {
  width: 180rpx;
  background: #fafafa;
  flex-shrink: 0;
}

.side-item {
  padding: 28rpx 16rpx;
  font-size: 24rpx;
  color: #666;
  border-left: 6rpx solid transparent;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.side-item.active {
  background: #fff;
  color: #3d2c1e;
  font-weight: 600;
  border-left-color: #e8b86d;
}

.side-icon {
  font-size: 32rpx;
}

.side-name {
  text-align: center;
  line-height: 1.3;
}

.list {
  flex: 1;
  background: #fff;
  padding: 0 16rpx;
}

.state {
  text-align: center;
  color: #999;
  padding: 80rpx 0;
  font-size: 28rpx;
}

.product-row {
  display: flex;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.thumb {
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
  background: #f8f0e8;
}

.thumb-emoji {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64rpx;
}

.info {
  flex: 1;
  margin-left: 16rpx;
  min-width: 0;
}

.name {
  font-size: 30rpx;
  font-weight: 600;
  color: #3d2c1e;
}

.meta {
  font-size: 22rpx;
  color: #c9986a;
  margin-top: 6rpx;
}

.desc {
  font-size: 22rpx;
  color: #999;
  margin-top: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.price-row {
  margin-top: 12rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.price {
  font-size: 32rpx;
  font-weight: 700;
  color: #c9986a;
}

.btn-spec {
  background: #e8b86d;
  color: #fff;
  font-size: 24rpx;
  padding: 10rpx 24rpx;
  border-radius: 999rpx;
}

.btn-add {
  width: 52rpx;
  height: 52rpx;
  line-height: 48rpx;
  text-align: center;
  background: #e8b86d;
  color: #fff;
  font-size: 36rpx;
  border-radius: 50%;
  font-weight: 300;
}

.list-pad {
  height: var(--kitchen-bottom-pad);
  min-height: 280rpx;
}
