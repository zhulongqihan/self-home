.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f5f5f5;
  box-sizing: border-box;
}

.search-row {
  flex-shrink: 0;
  padding: 24rpx 24rpx 28rpx;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}

.festival-bar {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  gap: 16rpx;
}

.festival-banner {
  width: 96rpx;
  height: 96rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.festival-text {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.festival-tag {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.85);
}

.festival-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
}

.festival-section {
  margin-bottom: 24rpx;
  padding-bottom: 8rpx;
  border-bottom: 1rpx dashed #e8b86d;
}

.festival-section-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #3d2c1e;
  margin-bottom: 16rpx;
}

.festival-product {
  background: #fffaf2;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
  padding: 12rpx;
}

.bullet-layer {
  position: fixed;
  left: 0;
  right: 0;
  top: 220rpx;
  height: 80rpx;
  overflow: hidden;
  z-index: 800;
  pointer-events: none;
}

.bullet-card {
  display: inline-flex;
  align-items: center;
  max-width: 85vw;
  white-space: nowrap;
  background: rgba(255, 248, 238, 0.96);
  border: 1rpx solid rgba(232, 184, 109, 0.55);
  border-radius: 999rpx;
  padding: 14rpx 32rpx;
  box-shadow: 0 8rpx 28rpx rgba(61, 44, 30, 0.14);
  animation: bullet-fly 18s linear infinite;
  transform: translateX(100vw);
}

.bullet-label {
  flex-shrink: 0;
  font-size: 22rpx;
  font-weight: 700;
  color: #e8b86d;
  margin-right: 12rpx;
}

.bullet-content {
  font-size: 26rpx;
  color: #3d2c1e;
  overflow: hidden;
  text-overflow: ellipsis;
}

@keyframes bullet-fly {
  0% {
    transform: translateX(100vw);
  }
  100% {
    transform: translateX(-120%);
  }
}

.search-placeholder {
  width: 100%;
  box-sizing: border-box;
  font-size: 26rpx;
  color: #999;
  background: #f5f5f5;
  padding: 18rpx 28rpx;
  border-radius: 999rpx;
  text-align: center;
  line-height: 1.4;
}

.main {
  flex: 1;
  display: flex;
  min-height: 0;
}

.side {
  width: 180rpx;
  background: #fafafa;
  flex-shrink: 0;
}

.side-item {
  padding: 28rpx 16rpx;
  font-size: 24rpx;
  color: #666;
  border-left: 6rpx solid transparent;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.side-item.active {
  background: #fff;
  color: #3d2c1e;
  font-weight: 600;
  border-left-color: #e8b86d;
}

.side-icon {
  font-size: 32rpx;
}

.side-name {
  text-align: center;
  line-height: 1.3;
}

.list {
  flex: 1;
  background: #fff;
  padding: 0 16rpx;
}

.state {
  text-align: center;
  color: #999;
  padding: 80rpx 0;
  font-size: 28rpx;
}

.product-row {
  display: flex;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.thumb {
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
  background: #f8f0e8;
}

.thumb-emoji {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64rpx;
}

.info {
  flex: 1;
  margin-left: 16rpx;
  min-width: 0;
}

.name {
  font-size: 30rpx;
  font-weight: 600;
  color: #3d2c1e;
}

.meta {
  font-size: 22rpx;
  color: #c9986a;
  margin-top: 6rpx;
}

.desc {
  font-size: 22rpx;
  color: #999;
  margin-top: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.price-row {
  margin-top: 12rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.price {
  font-size: 32rpx;
  font-weight: 700;
  color: #c9986a;
}

.btn-spec {
  background: #e8b86d;
  color: #fff;
  font-size: 24rpx;
  padding: 10rpx 24rpx;
  border-radius: 999rpx;
}

.btn-add {
  width: 52rpx;
  height: 52rpx;
  line-height: 48rpx;
  text-align: center;
  background: #e8b86d;
  color: #fff;
  font-size: 36rpx;
  border-radius: 50%;
  font-weight: 300;
}

.list-pad {
  height: var(--kitchen-bottom-pad);
  min-height: 280rpx;
}
