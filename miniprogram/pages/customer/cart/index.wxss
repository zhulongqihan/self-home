.page {
  min-height: 100vh;
  background: #FDF6EC;
  padding: 20rpx 20rpx 180rpx;
}

.state-text {
  text-align: center;
  color: #8f7560;
  margin-top: 180rpx;
  font-size: 28rpx;
}

.item-card {
  display: flex;
  background: #fff;
  border-radius: 18rpx;
  overflow: hidden;
  margin-bottom: 16rpx;
}

.item-cover {
  width: 180rpx;
  height: 180rpx;
  background: #f3ece3;
}

.item-main {
  flex: 1;
  padding: 16rpx;
}

.item-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #3d2c1e;
}

.item-specs {
  margin-top: 8rpx;
  color: #866c58;
  font-size: 22rpx;
}

.item-bottom {
  margin-top: 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.item-price {
  font-size: 30rpx;
  color: #c9986a;
  font-weight: 700;
}

.qty-box {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.qty-btn, .qty-val {
  width: 48rpx;
  height: 48rpx;
  line-height: 48rpx;
  border-radius: 10rpx;
  text-align: center;
  background: #f8f0e8;
  color: #634b3c;
}

.section {
  margin-top: 18rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
}

.label {
  color: #6f5745;
  font-size: 24rpx;
}

.picker-value {
  margin-top: 10rpx;
  background: #f8f0e8;
  border-radius: 12rpx;
  padding: 16rpx;
  color: #4f3a2f;
}

.note-input {
  margin-top: 10rpx;
  min-height: 120rpx;
  border-radius: 12rpx;
  background: #f8f0e8;
  padding: 14rpx;
  font-size: 24rpx;
}

.bottom {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 18rpx 20rpx calc(env(safe-area-inset-bottom) + 18rpx);
}

.total {
  color: #6f5745;
  font-size: 26rpx;
}

.total-price {
  color: #c9986a;
  font-size: 34rpx;
  font-weight: 700;
}

.submit-btn {
  background: #e8b86d;
  color: #fff;
  border-radius: 12rpx;
  padding: 18rpx 28rpx;
  font-size: 28rpx;
  font-weight: 600;
}
