.page {
  min-height: 100vh;
  background: #fdf6ec;
  padding: 40rpx;
  box-sizing: border-box;
}

.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  text-align: center;
}

.avatar {
  font-size: 100rpx;
}

.nickname {
  margin-top: 20rpx;
  font-size: 36rpx;
  font-weight: 600;
  color: #3d2c1e;
}

.coins {
  margin-top: 12rpx;
  font-size: 28rpx;
  color: #c9986a;
}

.store {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #999;
}

.sign-hint {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #e8b86d;
}

.loading-text {
  color: #bbb;
}

.actions {
  margin-top: 32rpx;
}

.btn-kiss,
.btn-sign {
  background: #e8b86d;
  color: #3d2c1e;
  text-align: center;
  padding: 28rpx;
  border-radius: 48rpx;
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
}

.btn-kiss.disabled,
.btn-sign.disabled {
  opacity: 0.5;
}

.kiss-meta {
  text-align: center;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 24rpx;
}

.logout {
  margin-top: 48rpx;
  text-align: center;
  color: #c9986a;
  font-size: 28rpx;
  padding: 24rpx;
}
