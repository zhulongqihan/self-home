<view class="page">
  <view class="header">
    <view class="store-name">{{store.name || '我们的小窝'}}</view>
    <view class="store-status">
      <text class="dot {{store.status === 'open' ? 'open' : 'closed'}}"></text>
      {{store.status === 'open' ? '营业中' : '店长打盹中 💤'}}
    </view>
  </view>

  <view class="greeting-card">
    <view class="greeting-emoji">🍵</view>
    <view class="greeting-text">{{greeting}}</view>
    <view class="user-info" wx:if="{{user}}">
      欢迎你，<text class="role">{{user.nickname || '宇宙第一可爱 VVVVVIP'}}</text>
    </view>
  </view>

  <view class="placeholder-card clickable" bindtap="goProducts">
    <view class="placeholder-title">🛍️ 商品分类</view>
    <view class="placeholder-desc">饮品 / 甜品 / 情绪服务已上线，点我开始下单</view>
  </view>

  <view class="placeholder-card clickable" bindtap="goCart">
    <view class="placeholder-title">🛒 购物车</view>
    <view class="placeholder-desc">查看已选商品并提交订单</view>
  </view>

  <view class="logout" bindtap="onLogout">退出登录</view>
</view>