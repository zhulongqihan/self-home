.page {
  min-height: 100vh;
  background: #FDF6EC;
  padding-bottom: 160rpx;
}

.state-text {
  text-align: center;
  margin-top: 160rpx;
  font-size: 28rpx;
  color: #8f7560;
}

.swiper {
  height: 440rpx;
}

.cover {
  width: 100%;
  height: 100%;
}

.card {
  background: #fff;
  border-radius: 20rpx;
  margin: 20rpx;
  padding: 24rpx;
}

.name {
  font-size: 36rpx;
  font-weight: 700;
  color: #3d2c1e;
}

.price {
  margin-top: 12rpx;
  font-size: 34rpx;
  color: #c9986a;
  font-weight: 700;
}

.desc {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #7c614d;
  line-height: 1.6;
}

.section-title {
  font-size: 28rpx;
  color: #3d2c1e;
  font-weight: 600;
}

.spec-block + .spec-block {
  margin-top: 18rpx;
}

.spec-name {
  margin-top: 14rpx;
  color: #6f5745;
  font-size: 24rpx;
}

.spec-options {
  margin-top: 10rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.spec-option {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: #f8f0e8;
  color: #7b614e;
  font-size: 22rpx;
}

.spec-option.active {
  background: #e8b86d;
  color: #fff;
}

.qty-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.qty-box {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.qty-btn, .qty-val {
  width: 56rpx;
  height: 56rpx;
  border-radius: 12rpx;
  text-align: center;
  line-height: 56rpx;
  background: #f8f0e8;
  color: #5f4738;
}

.qty-val {
  background: #fff4e2;
}

.bottom-actions {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  padding: 18rpx 20rpx calc(env(safe-area-inset-bottom) + 18rpx);
  display: flex;
  gap: 16rpx;
}

.btn {
  flex: 1;
  text-align: center;
  border-radius: 14rpx;
  padding: 20rpx 0;
  font-size: 28rpx;
}

.btn.secondary {
  background: #f8f0e8;
  color: #7c604c;
}

.btn.primary {
  background: #e8b86d;
  color: #fff;
  font-weight: 600;
}
