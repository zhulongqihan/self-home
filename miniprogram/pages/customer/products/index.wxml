<view class="page">
  <scroll-view class="category-scroll" scroll-x enhanced show-scrollbar="{{false}}">
    <view class="category-row">
      <view
        wx:for="{{categories}}"
        wx:key="id"
        class="category-chip {{item.id === activeCategoryId ? 'active' : ''}}"
        data-id="{{item.id}}"
        bindtap="onSwitchCategory"
      >
        <text>{{item.icon || '🍵'}}</text>
        <text class="chip-name">{{item.name}}</text>
      </view>
    </view>
  </scroll-view>

  <view wx:if="{{loading}}" class="state-text">加载中...</view>
  <view wx:elif="{{!products.length}}" class="state-text">这个分类还没有商品哦</view>

  <view wx:else class="product-grid">
    <view
      wx:for="{{products}}"
      wx:key="_id"
      class="product-card"
      data-id="{{item._id}}"
      bindtap="onTapProduct"
    >
      <image class="product-cover" src="{{(item.images && item.images[0]) || ''}}" mode="aspectFill" />
      <view class="product-name">{{item.name}}</view>
      <view class="product-desc">{{item.description}}</view>
      <view class="product-footer">
        <text class="product-price">¥{{item.price}}</text>
        <text class="product-go">去看看</text>
      </view>
    </view>
  </view>
</view>
