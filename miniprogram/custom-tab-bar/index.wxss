.tab-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  box-sizing: border-box;
  /* 避免部分基础库对 calc(env()) 兼容性问题导致高度为 0 */
  height: 112rpx;
  min-height: 112rpx;
  padding-bottom: env(safe-area-inset-bottom);
  background: #fff;
  border-top: 1rpx solid #eee;
  display: flex;
  z-index: 400;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #999;
  font-size: 22rpx;
}

.tab-item.active {
  color: #e8b86d;
  font-weight: 600;
}

.tab-icon {
  font-size: 40rpx;
  line-height: 1.2;
}

.tab-text {
  margin-top: 4rpx;
}
