/* 组件内自包含布局变量（避免样式隔离读不到 page 变量） */
.wrap {
  --tab-bar-content-h: 112rpx;
  --tab-bar-total-h: calc(var(--tab-bar-content-h) + env(safe-area-inset-bottom));
  --cart-bar-h: 96rpx;
  position: fixed;
  left: 0;
  right: 0;
  bottom: var(--tab-bar-total-h);
  z-index: 200;
  /* 仅包裹底部购物车条高度，避免误挡上方商品列表点击 */
  top: auto;
  width: 100%;
  height: auto;
  overflow: visible;
}

.mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  z-index: 99;
}

.drawer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: var(--tab-bar-total-h);
  max-height: 50vh;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  z-index: 101;
  padding: 24rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

.drawer-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #3d2c1e;
  margin-bottom: 16rpx;
}

.drawer-empty {
  text-align: center;
  color: #999;
  padding: 40rpx;
}

.drawer-list {
  flex: 1;
  max-height: 280rpx;
}

.drawer-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.drawer-name {
  font-size: 28rpx;
  color: #3d2c1e;
}

.drawer-specs {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.drawer-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 8rpx;
}

.drawer-price {
  color: #c9986a;
  font-weight: 600;
}

.qty-box {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.qty-btn, .qty-val {
  width: 48rpx;
  height: 48rpx;
  line-height: 48rpx;
  text-align: center;
  background: #f8f0e8;
  border-radius: 8rpx;
}

.drawer-form {
  margin-top: 16rpx;
}

.picker-line {
  font-size: 26rpx;
  color: #666;
  padding: 12rpx 0;
}

.note {
  width: 100%;
  min-height: 80rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 12rpx;
  font-size: 24rpx;
  box-sizing: border-box;
}

.bar {
  margin: 0 20rpx;
  min-height: var(--cart-bar-h);
  background: #fff;
  border-radius: 999rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.12);
  display: flex;
  align-items: center;
  padding: 12rpx 16rpx 12rpx 24rpx;
  z-index: 202;
  position: relative;
  box-sizing: border-box;
}

.cart-icon-wrap {
  position: relative;
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cart-icon {
  font-size: 44rpx;
}

.badge {
  position: absolute;
  top: 0;
  right: 0;
  min-width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  text-align: center;
  background: #e85d5d;
  color: #fff;
  font-size: 20rpx;
  border-radius: 999rpx;
  padding: 0 8rpx;
}

.bar-mid {
  flex: 1;
  padding: 0 16rpx;
}

.empty-hint {
  color: #999;
  font-size: 26rpx;
}

.total {
  font-size: 36rpx;
  font-weight: 700;
  color: #3d2c1e;
}

.submit {
  background: #ddd;
  color: #fff;
  padding: 20rpx 36rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.submit.active {
  background: #e8b86d;
}
