/* 暖阳大地主题（默认） */
:root {
  --primary-color: #E8B86D;
  --secondary-color: #C9986A;
  --background-color: #FDF6EC;
  --card-background: #FFFFFF;
  --text-color: #3D2C1E;
  --border-color: #E8E8E8;
}

/* 云朵白主题 */
[data-theme="cloud"] {
  --primary-color: #FFFFFF;
  --secondary-color: #E8B86D;
  --background-color: #F8F8F8;
  --card-background: #FFFFFF;
  --text-color: #222222;
  --border-color: #E8E8E8;
}